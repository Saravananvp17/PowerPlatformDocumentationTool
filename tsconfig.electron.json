{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist-electron",
    "baseUrl": ".",
    "paths": { "@/*": ["src/*"] }
  },
  "include": ["electron/**/*", "src/**/*"],
  "exclude": ["node_modules", "renderer", "dist-electron", "dist-renderer"]
}
